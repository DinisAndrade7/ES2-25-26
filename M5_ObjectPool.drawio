        <mxCell id="fp_a" value="- available : ConcurrentLinkedQueue&lt;MessageFormatter&gt;&#xa;- maxSize : int&#xa;- totalCreated : int" style="text;html=1;align=left;spacingLeft=4;fontSize=10;" vertex="1" parent="formpool"><mxGeometry x="0" y="46" width="300" height="54" as="geometry"/></mxCell>
        <mxCell id="fp_sep2" value="" style="line;strokeColor=#9673a6;" vertex="1" parent="formpool"><mxGeometry x="0" y="104" width="300" height="6" as="geometry"/></mxCell>
        <mxCell id="fp_m" value="+ FormatterPool(maxSize : int)&#xa;  {pre-warms pool with 2 instances}&#xa;+ acquire() : MessageFormatter&#xa;  {poll from queue or createNew()}&#xa;+ release(fmt : MessageFormatter) : void&#xa;  {calls reset() then returns to queue}&#xa;- createNew() : MessageFormatter&#xa;  {totalCreated++, new instance}&#xa;+ getAvailableCount() : int&#xa;+ getTotalCreated() : int" style="text;html=1;align=left;spacingLeft=4;fontSize=10;" vertex="1" parent="formpool"><mxGeometry x="0" y="110" width="300" height="146" as="geometry"/></mxCell>

        <!-- MessageFormatter -->
