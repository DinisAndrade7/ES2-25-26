        <mxCell id="mf_m" value="+ MessageFormatter(pattern : String)&#xa;+ format(record : LogRecord) : String&#xa;  {usageCount++ then record.format(pattern)}&#xa;+ setPattern(pattern : String) : void&#xa;  {Strategy — swap algorithm at runtime}&#xa;+ reset() : void&#xa;  {resets usageCount for pool reuse}&#xa;+ getPattern() : String&#xa;+ getUsageCount() : int&#xa;+ toString() : String" style="text;html=1;align=left;spacingLeft=4;fontSize=10;" vertex="1" parent="msgfmt"><mxGeometry x="0" y="100" width="280" height="156" as="geometry"/></mxCell>

