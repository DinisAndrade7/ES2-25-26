        <mxCell id="m5r1" value="acquire() / release()" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;strokeColor=#d6781e;fontSize=10;" edge="1" parent="1" source="formpool" target="msgfmt"><mxGeometry relative="1" as="geometry"/></mxCell>
