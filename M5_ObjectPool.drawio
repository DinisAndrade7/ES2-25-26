        <!-- Pool lifecycle note -->
        <mxCell id="note_pool" value="Object Pool Pattern:&#xa;1. acquire() → tira da ConcurrentLinkedQueue&#xa;2. Formata o LogRecord com MessageFormatter&#xa;3. release() → reset() + devolve à fila&#xa;&#xa;Strategy Pattern embutido:&#xa;setPattern() troca o algoritmo de&#xa;formatação em tempo de execução.&#xa;&#xa;Thread-safe: ConcurrentLinkedQueue garante&#xa;acesso seguro a partir de múltiplas threads." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=10;spacingLeft=6;" vertex="1" parent="1">
