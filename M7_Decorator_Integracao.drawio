        <!-- Notes -->
        <mxCell id="note_dec" value="Decorator Pattern:&#xa;new ExtensionBuilder()&#xa;  .withTimestampEnricher()&#xa;  .withMonitoring(endpoint)&#xa;  .withAdminAlerts(ERROR, email)&#xa;  .withErrorPatternAnalysis(3)&#xa;  .build();&#xa;&#xa;Cada wrapper chama before()&#xa;→ wrapped.process()&#xa;→ after()&#xa;&#xa;Adicionar nova extensão:&#xa;criar nova subclasse de&#xa;LogExtensionDecorator — sem&#xa;alterar o sistema principal." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#e6ffe6;strokeColor=#1a7a1a;align=left;fontSize=10;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="1100" y="530" width="270" height="290" as="geometry"/>
        </mxCell>

        <!-- Integration note -->
        <mxCell id="note_flow" value="Fluxo LogManager.log():&#xa;1. M2 LogFactory.create() → LogRecord&#xa;2. M4 LogCategory.add(LogLeaf)&#xa;3. M5 FormatterPool.acquire()&#xa;      MessageFormatter.format()&#xa;   FormatterPool.release()&#xa;4. M3 LogDestination.write()&#xa;      (para cada destino ativo)&#xa;5. M7 LogExtension.process()&#xa;      (pipeline de decoradores)&#xa;   ↳ before() hooks&#xa;   ↳ delegate to next&#xa;   ↳ after() hooks&#xa;&#xa;M1 LogConfiguration.isLevelActive()&#xa;   é verificado em M2 (buildLog)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=10;spacingLeft=6;" vertex="1" parent="1">
