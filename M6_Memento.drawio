        <mxCell id="formpool_sm" value="FormatterPool  «pool»" style="swimlane;startSize=20;fillColor=#f9dbc8;strokeColor=#d6781e;fontStyle=1;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="560" y="160" width="200" height="40" as="geometry"/>
