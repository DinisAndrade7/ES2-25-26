        </mxCell>
        <mxCell id="ll_v" value="DEBUG/INFO&#xa;WARNING/ERROR" style="text;html=1;align=left;spacingLeft=4;fontSize=9;" vertex="1" parent="loglevel"><mxGeometry x="0" y="20" width="100" height="36" as="geometry"/></mxCell>

        <mxCell id="logconfig" value="LogConfiguration  «singleton»" style="swimlane;startSize=20;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="140" y="40" width="200" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="lc_v" value="- instance {static volatile}&#xa;- minimumLevel: LogLevel&#xa;- messageFormat: String&#xa;- activeDestinations: Set&#xa;- activeFilters: Set&#xa;- timestampEnabled: boolean&#xa;&#xa;- LogConfiguration() {private}&#xa;+ getInstance(): LogConfiguration&#xa;+ isLevelActive(lvl): boolean&#xa;+ setMinimumLevel(lvl): void&#xa;+ addDestination(dest): void" style="text;html=1;align=left;spacingLeft=4;fontSize=9;" vertex="1" parent="logconfig"><mxGeometry x="0" y="20" width="200" height="134" as="geometry"/></mxCell>

