        </mxCell>
        <mxCell id="ld_v" value="+ write(record, msg): void&#xa;+ getName(): String&#xa;+ isAvailable(): boolean&#xa;+ close(): void" style="text;html=1;align=left;spacingLeft=4;fontSize=9;" vertex="1" parent="logdest"><mxGeometry x="0" y="20" width="180" height="74" as="geometry"/></mxCell>

        <mxCell id="logcomp" value="LogComponent  «interface»" style="swimlane;startSize=20;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=9;" vertex="1" parent="1">
