        <!-- ████ M6 — MEMENTO ████ -->
        <mxCell id="m6_label" value="M6 — Memento: Armazenamento de Estado do Sistema de Logs" style="text;html=1;fontSize=13;fontStyle=1;fillColor=#d0e0ff;strokeColor=#3050a0;align=center;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="10" y="230" width="1100" height="26" as="geometry"/>
        </mxCell>

        <!-- LogSystemOriginator -->
        <mxCell id="originator" value="LogSystemOriginator" style="swimlane;startSize=22;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="10" y="270" width="340" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="orig_s" value="«originator»" style="text;html=1;fontSize=9;fontStyle=2;align=center;" vertex="1" parent="originator"><mxGeometry x="0" y="22" width="340" height="14" as="geometry"/></mxCell>
        <mxCell id="orig_sep1" value="" style="line;strokeColor=#9673a6;" vertex="1" parent="originator"><mxGeometry x="0" y="40" width="340" height="6" as="geometry"/></mxCell>
        <mxCell id="orig_a" value="- config : LogConfiguration" style="text;html=1;align=left;spacingLeft=4;fontSize=10;" vertex="1" parent="originator"><mxGeometry x="0" y="46" width="340" height="24" as="geometry"/></mxCell>
        <mxCell id="orig_sep2" value="" style="line;strokeColor=#9673a6;" vertex="1" parent="originator"><mxGeometry x="0" y="74" width="340" height="6" as="geometry"/></mxCell>
        <mxCell id="orig_m" value="+ LogSystemOriginator()&#xa;  {injects LogConfiguration.getInstance()}&#xa;&#xa;+ save(label : String) : LogSystemMemento&#xa;  {reads state from LogConfiguration&#xa;   and packs into new Memento}&#xa;&#xa;+ restore(m : LogSystemMemento) : void&#xa;  {unpacks Memento and applies state&#xa;   back to LogConfiguration}&#xa;&#xa;+ getCurrentLevel() : LogLevel&#xa;  {reads from LogConfiguration}" style="text;html=1;align=left;spacingLeft=4;fontSize=10;" vertex="1" parent="originator"><mxGeometry x="0" y="80" width="340" height="176" as="geometry"/></mxCell>

        <!-- LogSystemMemento -->
        <mxCell id="memento" value="LogSystemMemento" style="swimlane;startSize=22;fillColor=#d0e0ff;strokeColor=#3050a0;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="270" width="360" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="mem_s" value="«memento»" style="text;html=1;fontSize=9;fontStyle=2;align=center;" vertex="1" parent="memento"><mxGeometry x="0" y="22" width="360" height="14" as="geometry"/></mxCell>
        <mxCell id="mem_sep1" value="" style="line;strokeColor=#3050a0;" vertex="1" parent="memento"><mxGeometry x="0" y="40" width="360" height="6" as="geometry"/></mxCell>
        <mxCell id="mem_a" value="~ minimumLevel : LogLevel  {package-private}&#xa;~ activeDestinations : Set&lt;String&gt;  {package-private}&#xa;~ activeFilters : Set&lt;String&gt;  {package-private}&#xa;~ messageFormat : String  {package-private}&#xa;~ timestampEnabled : boolean  {package-private}&#xa;- savedAt : LocalDateTime  {private}&#xa;- label : String  {private}" style="text;html=1;align=left;spacingLeft=4;fontSize=10;" vertex="1" parent="memento"><mxGeometry x="0" y="46" width="360" height="120" as="geometry"/></mxCell>
        <mxCell id="mem_sep2" value="" style="line;strokeColor=#3050a0;" vertex="1" parent="memento"><mxGeometry x="0" y="170" width="360" height="6" as="geometry"/></mxCell>
        <mxCell id="mem_m" value="~ LogSystemMemento(level, destinations,&#xa;   filters, format, timestamp, label)&#xa;   {package-private — only Originator creates}&#xa;&#xa;~ getMinimumLevel() : LogLevel  {pkg-private}&#xa;~ getActiveDestinations() : Set  {pkg-private}&#xa;~ getActiveFilters() : Set  {pkg-private}&#xa;~ getMessageFormat() : String  {pkg-private}&#xa;~ isTimestampEnabled() : boolean  {pkg-private}&#xa;&#xa;+ getSavedAt() : LocalDateTime  {public}&#xa;+ getLabel() : String  {public — metadata only}&#xa;+ toString() : String" style="text;html=1;align=left;spacingLeft=4;fontSize=10;" vertex="1" parent="memento"><mxGeometry x="0" y="176" width="360" height="120" as="geometry"/></mxCell>

        <!-- LogSystemCaretaker -->
        <mxCell id="caretaker" value="LogSystemCaretaker" style="swimlane;startSize=22;fillColor=#ffe6cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="760" y="270" width="340" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="ct_s" value="«caretaker»" style="text;html=1;fontSize=9;fontStyle=2;align=center;" vertex="1" parent="caretaker"><mxGeometry x="0" y="22" width="340" height="14" as="geometry"/></mxCell>
        <mxCell id="ct_sep1" value="" style="line;strokeColor=#d6b656;" vertex="1" parent="caretaker"><mxGeometry x="0" y="40" width="340" height="6" as="geometry"/></mxCell>
        <mxCell id="ct_a" value="- originator : LogSystemOriginator&#xa;- history : Deque&lt;LogSystemMemento&gt;&#xa;- future : Deque&lt;LogSystemMemento&gt;" style="text;html=1;align=left;spacingLeft=4;fontSize=10;" vertex="1" parent="caretaker"><mxGeometry x="0" y="46" width="340" height="54" as="geometry"/></mxCell>
        <mxCell id="ct_sep2" value="" style="line;strokeColor=#d6b656;" vertex="1" parent="caretaker"><mxGeometry x="0" y="104" width="340" height="6" as="geometry"/></mxCell>
        <mxCell id="ct_m" value="+ LogSystemCaretaker(originator)&#xa;&#xa;+ checkpoint(label : String) : void&#xa;  {calls originator.save() → push to history&#xa;   clears future stack (invalidates redo)}&#xa;&#xa;+ undo() : boolean&#xa;  {push current to future, pop history,&#xa;   calls originator.restore(previous)}&#xa;&#xa;+ redo() : boolean&#xa;  {push current to history, pop future,&#xa;   calls originator.restore(next)}&#xa;&#xa;+ getHistory() : List&lt;LogSystemMemento&gt;&#xa;+ getHistorySize() : int" style="text;html=1;align=left;spacingLeft=4;fontSize=10;" vertex="1" parent="caretaker"><mxGeometry x="0" y="110" width="340" height="186" as="geometry"/></mxCell>

        <!-- M6 Relations -->
        <!-- Originator creates Memento -->
        <mxCell id="m6r1" value="«creates»" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;dashed=1;strokeColor=#3050a0;fontSize=10;" edge="1" parent="1" source="originator" target="memento"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- Originator reads/writes LogConfiguration (M1) -->
        <mxCell id="m6r2" value="reads/writes M1" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;dashed=1;strokeColor=#82b366;fontSize=9;" edge="1" parent="1" source="originator" target="logconfig"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- Caretaker uses Originator -->
        <mxCell id="m6r3" value="«uses»" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;strokeColor=#d6b656;fontSize=10;" edge="1" parent="1" source="caretaker" target="originator"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- Caretaker stores Memento -->
        <mxCell id="m6r4" value="stores" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;strokeColor=#3050a0;fontSize=10;" edge="1" parent="1" source="caretaker" target="memento"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Memento encapsulation note -->
        <mxCell id="note_mem" value="Memento Pattern — Encapsulamento:&#xa;• ~ (package-private) = apenas Originator acede&#xa;• + (public) = apenas metadados (label, savedAt)&#xa;• Caretaker NUNCA lê o conteúdo do Memento&#xa;• Originator é o único que sabe como criar/restaurar&#xa;&#xa;Undo/Redo com pilhas duplas:&#xa;• checkpoint() → push history, clear future&#xa;• undo()       → push future, pop history, restore&#xa;• redo()       → push history, pop future, restore" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=10;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="10" y="590" width="440" height="160" as="geometry"/>
        </mxCell>

        <!-- Memento state diagram -->
        <mxCell id="state_note" value="Estado guardado no Memento:&#xa;• minimumLevel (ex: DEBUG → WARNING)&#xa;• activeDestinations (CONSOLE, FILE, DB)&#xa;• activeFilters (filtros ativos)&#xa;• messageFormat (padrão de formatação)&#xa;• timestampEnabled (true/false)&#xa;• savedAt (quando foi guardado)&#xa;• label (identificador descritivo)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#d0e0ff;strokeColor=#3050a0;align=left;fontSize=10;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="470" y="590" width="300" height="160" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
