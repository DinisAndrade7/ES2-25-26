          <mxGeometry x="360" y="40" width="180" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="lr_v" value="- level: LogLevel&#xa;- message: String&#xa;- category: String&#xa;- timestamp: LocalDateTime&#xa;&#xa;+ format(pattern): String&#xa;+ getLevel(): LogLevel" style="text;html=1;align=left;spacingLeft=4;fontSize=9;" vertex="1" parent="logrecord"><mxGeometry x="0" y="20" width="180" height="104" as="geometry"/></mxCell>

        <mxCell id="logdest" value="LogDestination  «interface»" style="swimlane;startSize=20;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=9;" vertex="1" parent="1">
